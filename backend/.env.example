# Backend environment variables (example)
# Copy to `backend/.env` and fill real values.

# Server
PORT=5000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5000
MAINTENANCE_CACHE_MS=15000

# Database (MySQL)
# Example: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://root:password@localhost:3306/localbasket

# Auth
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# Razorpay (Payments)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# Cloudinary (Uploads)
CLOUDINARY_CLOUD_NAME=xxxxxxxx
CLOUDINARY_API_KEY=xxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxx

# Email (OTP via SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your_user
EMAIL_PASS=your_pass
EMAIL_FROM=LocalBasket <no-reply@example.com>
EMAIL_REPLY_TO=support@example.com
EMAIL_VERIFY_TRANSPORT=false

# OTP settings
OTP_PROVIDER=email
OTP_DEBUG_RETURN=false

# WhatsApp OTP (Meta / Graph API) - optional
WHATSAPP_TOKEN=xxxxxxxx
PHONE_NUMBER_ID=xxxxxxxx
WHATSAPP_TEMPLATE_NAME=xxxxxxxx
WHATSAPP_TEMPLATE_LANG=en

# Twilio OTP (SMS) - optional
TWILIO_ACCOUNT_SID=xxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_FROM_NUMBER=+10000000000
TWILIO_MESSAGING_SERVICE_SID=xxxxxxxx

# Invoice customization (optional)
INVOICE_BRAND_NAME=Local Basket
INVOICE_GSTIN=
INVOICE_SUPPORT=support@localbasket.com
INVOICE_ADDRESS=
INVOICE_LOGO_PATH=
INVOICE_GST_RATE=0
INVOICE_QR_TEXT=
INVOICE_TERMS=

